SILICONFLOW_API_KEY=your_siliconflow_api_key_here
LLM_BASE_URL=https://api.siliconflow.cn/v1
LLM_MODEL=deepseek-ai/DeepSeek-V4-Flash
VISION_BASE_URL=https://api.siliconflow.cn/v1
VISION_MODEL=Qwen/Qwen3-VL-8B-Instruct
VISION_MAX_TOKENS=320
EMBEDDING_BASE_URL=https://api.siliconflow.cn/v1
EMBEDDING_MODEL=Qwen/Qwen3-Embedding-0.6B
LLM_INPUT_CNY_PER_MTOK=1.0
LLM_OUTPUT_CNY_PER_MTOK=2.0
EMBEDDING_CNY_PER_MTOK=0.08
LLM_TIMEOUT_SECONDS=30
DATABASE_URL=postgresql+psycopg://postgres:postgres@127.0.0.1:5433/customer_email_agent
JWT_SECRET=replace_with_a_long_random_secret_in_production
JWT_EXPIRE_MINUTES=720
DEFAULT_ADMIN_PASSWORD=Admin123456
QQ_EMAIL_ADDRESS=your_qq_email@qq.com
QQ_EMAIL_AUTH_CODE=your_qq_mail_auth_code
QQ_IMAP_HOST=imap.qq.com
QQ_IMAP_PORT=993
QQ_SMTP_HOST=smtp.qq.com
QQ_SMTP_PORT=465

# 当前活动邮件源：qq / outlook / gmail。也可以在系统设置中测试后切换。
MAIL_PROVIDER=qq
# 用于加密数据库中的邮箱授权码和客户端密钥。生产环境请设置为 Fernet key。
MAIL_CONFIG_ENCRYPTION_KEY=

# Gmail 使用开启两步验证后生成的应用专用密码。
GMAIL_EMAIL_ADDRESS=your_account@gmail.com
GMAIL_APP_PASSWORD=your_gmail_app_password
GMAIL_IMAP_HOST=imap.gmail.com
GMAIL_IMAP_PORT=993
GMAIL_SMTP_HOST=smtp.gmail.com
GMAIL_SMTP_PORT=465

# Outlook 使用 Microsoft Graph 应用权限（Mail.Read / Mail.Send）。
OUTLOOK_EMAIL_ADDRESS=mailbox@your-tenant.com
OUTLOOK_TENANT_ID=your_tenant_id
OUTLOOK_CLIENT_ID=your_client_id
OUTLOOK_CLIENT_SECRET=your_client_secret
OUTLOOK_REDIRECT_URI=
